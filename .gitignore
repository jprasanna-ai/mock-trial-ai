# =============================================================================
# Mock Trial AI - Git Ignore
# =============================================================================

# =============================================================================
# ENVIRONMENT FILES (CRITICAL - Never commit API keys!)
# =============================================================================
.env
.env.local
.env.*.local
*.env
backend/.env
frontend/.env.local

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
ENV/
*.egg-info/
dist/
build/
.eggs/
*.egg

# =============================================================================
# NODE.JS / NEXT.JS
# =============================================================================
node_modules/
# Vercel CLI link (anywhere in repo)
**/.vercel/
.next/
out/
.nuxt/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# IDE / EDITORS
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# TESTING / COVERAGE
# =============================================================================
.coverage
htmlcov/
.pytest_cache/
.tox/
coverage/
*.cover

# =============================================================================
# LOGS
# =============================================================================
*.log
logs/

# =============================================================================
# DATABASE
# =============================================================================
*.sqlite3
*.db

# =============================================================================
# MISC
# =============================================================================
.cache/
tmp/
temp/

# =============================================================================
# AGENT PREP CACHE (local file fallback for LLM-generated prep materials)
# =============================================================================
.agent_prep_cache/

# =============================================================================
# GENERATED AUDIO FILES (cached TTS audio — stored in Supabase, not git)
# =============================================================================
backend/app/data/prep_cache/audio/
backend/app/data/prep_cache/tts/
